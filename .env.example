# Required: Your NWC connection string from your Lightning wallet
TRANDOR_NWC=nostr+walletconnect://WALLET_PUBKEY?relay=wss://relay.example.com&secret=YOUR_SECRET

# Optional: Trandor API base URL (default: https://api.trandor.com)
# TRANDOR_BASE_URL=https://api.trandor.com

# Optional: Port to run the proxy on (default: 8745)
# PORT=8745
